# Backend build context
# Keep this minimal — Maven runs inside the image and re-builds everything.

# Build output
target/
build/
out/
*.class
*.jar
*.war
hs_err_pid*
replay_pid*

# Maven local files
.mvn/timing.properties
dependency-reduced-pom.xml
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next

# Logs / embedded DB files
logs/
*.log
spring.log*
*.db
*.mv.db
*.trace.db
*.lck
derby.log

# Local config / secrets — pass real config via env vars in compose/k8s
application-local.properties
application-local.yml
application-secret*.properties
application-secret*.yml
.env
.env.*
!.env.example

# VCS / docs / editor / OS
.git/
.gitignore
.gitattributes
.github/
README.md
docs/
.idea/
*.iml
.vscode/
.classpath
.project
.settings/
.DS_Store
Thumbs.db

# Don't bake the Dockerfile / dockerignore into the image
Dockerfile
.dockerignore
